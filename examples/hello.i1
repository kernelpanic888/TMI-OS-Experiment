program HelloSandbox

chain:
  LLM/GPT/Codex -> Lean -> TLFL -> И1

intent:
  "проверить маленькую идею без публикации"

record:
  CanonicalRecord := Intent -> Passport -> GuardedAction

passport:
  sandbox := true
  public_claim := false
  secrets_allowed := false

guard:
  no_private_data
  no_overclaim
  no_auto_publish

action:
  print "sandbox ready"

